{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user (Admin or Worker)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "worker", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Pool": {
      "title": "Pool",
      "description": "Pool location and details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "clientId": { "type": "string" }
      },
      "required": ["name", "address"]
    },
    "Route": {
      "title": "Route",
      "description": "Daily route for a worker or a template with scheduling",
      "type": "object",
      "properties": {
        "routeName": { "type": "string", "description": "Optional name for the route (e.g. 'Ruta Norte')" },
        "workerId": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "Specific date for single-day routes" },
        "startDate": { "type": "string", "format": "date", "description": "Start date for scheduled routes" },
        "endDate": { "type": "string", "format": "date", "description": "End date for scheduled routes" },
        "recurrence": { "type": "string", "enum": ["none", "daily", "weekly", "bi-weekly", "monthly"] },
        "daysOfWeek": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 6 },
          "description": "0=Sun, 1=Mon, etc."
        },
        "poolIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "order": { "type": "integer", "description": "Display order for templates" },
        "assignedDay": { "type": "integer", "minimum": 0, "maximum": 6, "description": "Day of week assigned in the weekly plan (0=Sun, 1=Mon...)" }
      },
      "required": ["poolIds"]
    },
    "Log": {
      "title": "Log",
      "description": "Service log for a pool visit",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "poolId": { "type": "string" },
        "arrivalTime": { "type": "string", "format": "date-time" },
        "departureTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ok", "issue"] },
        "notes": { "type": "string" },
        "notifyClient": { "type": "boolean", "description": "Whether to show this log to the client" },
        "photos": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["workerId", "poolId", "arrivalTime", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/pools/{poolId}": {
      "schema": "Pool",
      "description": "Pool registry"
    },
    "/routes/{routeId}": {
      "schema": "Route",
      "description": "Daily worker routes"
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Service visit logs"
    }
  }
}
