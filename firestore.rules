rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: name (string), email (string), role (string: admin|worker)
    //
    // Collection: pools
    // Fields: name (string), address (string), coordinates (map), clientId (string)
    //
    // Collection: routes
    // Fields: workerId (string), date (string), poolIds (list), status (string)
    //
    // Collection: logs
    // Fields: workerId (string), poolId (string), arrivalTime (timestamp), departureTime (timestamp), status (string), notes (string), photos (list)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "sasegura.fernandez87@gmail.com" || 
         hasRole('admin'));
    }
    
    function isWorker() {
      return hasRole('worker');
    }
    
    function isClient() {
      return hasRole('client');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Pools collection
    match /pools/{poolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Routes collection
    match /routes/{routeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || (isWorker() && request.resource.data.workerId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // Logs collection
    match /logs/{logId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isWorker() || 
        (isClient() && 
         get(/databases/$(database)/documents/pools/$(resource.data.poolId)).data.clientId == request.auth.uid &&
         (resource.data.status == 'ok' || resource.data.get('notifyClient', true) == true))
      );
      allow create: if isAuthenticated() && (isAdmin() || isWorker());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
