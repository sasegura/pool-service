rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function membershipDoc(companyId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(companyId));
    }

    function hasActiveMembership(companyId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(companyId))
        && membershipDoc(companyId).data.status == 'active';
    }

    function memberRole(companyId) {
      return membershipDoc(companyId).data.role;
    }

    function isStaff(companyId) {
      return hasActiveMembership(companyId)
        && memberRole(companyId) in ['admin', 'supervisor', 'technician'];
    }

    function isAdminOrSupervisor(companyId) {
      return hasActiveMembership(companyId)
        && memberRole(companyId) in ['admin', 'supervisor'];
    }

    function isCompanyAdmin(companyId) {
      return hasActiveMembership(companyId) && memberRole(companyId) == 'admin';
    }

    function isPortalClient(companyId) {
      return hasActiveMembership(companyId) && memberRole(companyId) == 'client';
    }

    function isTechnician(companyId) {
      return hasActiveMembership(companyId) && memberRole(companyId) == 'technician';
    }

    function poolDoc(companyId, poolId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/pools/$(poolId));
    }

    function poolOwnedByClient(companyId, poolId) {
      return exists(/databases/$(database)/documents/companies/$(companyId)/pools/$(poolId))
        && poolDoc(companyId, poolId).data.clientId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;

      match /memberships/{companyId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;

        allow create: if isAuthenticated()
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['companyId', 'role', 'status'])
          && request.resource.data.companyId == companyId
          && request.resource.data.role == 'admin'
          && request.resource.data.status == 'active'
          && existsAfter(/databases/$(database)/documents/companies/$(companyId))
          && getAfter(/databases/$(database)/documents/companies/$(companyId)).data.createdByUid == request.auth.uid
          && !exists(/databases/$(database)/documents/users/$(userId)/memberships/$(companyId));

        allow create: if isAuthenticated()
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['companyId', 'role', 'status', 'fromInvitedMemberId'])
          && request.resource.data.companyId == companyId
          && request.resource.data.status == 'active'
          && request.auth.token.email != null
          && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.resource.data.fromInvitedMemberId))
          && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.resource.data.fromInvitedMemberId)).data.status == 'invited'
          && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.resource.data.fromInvitedMemberId)).data.email == request.auth.token.email
          && request.resource.data.role == get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.resource.data.fromInvitedMemberId)).data.role
          && !exists(/databases/$(database)/documents/users/$(userId)/memberships/$(companyId));

        allow update: if isCompanyAdmin(companyId)
          && request.auth.uid != userId
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.status == resource.data.status
          && request.resource.data.role in ['admin', 'supervisor', 'technician', 'client'];

        allow delete: if isCompanyAdmin(companyId) && request.auth.uid != userId;
      }
    }

    match /companies/{companyId} {
      allow read: if hasActiveMembership(companyId);

      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['name', 'status', 'createdByUid'])
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.status == 'active';

      allow update: if isAdminOrSupervisor(companyId);
      allow delete: if false;

      match /members/{memberId} {
        allow get: if hasActiveMembership(companyId)
          || (
            isAuthenticated()
            && resource.data.status == 'invited'
            && request.auth.token.email != null
            && resource.data.email == request.auth.token.email
          );

        allow list: if hasActiveMembership(companyId);

        allow create: if isAuthenticated()
          && request.auth.uid == memberId
          && existsAfter(/databases/$(database)/documents/companies/$(companyId))
          && getAfter(/databases/$(database)/documents/companies/$(companyId)).data.createdByUid == request.auth.uid
          && request.resource.data.uid == memberId
          && request.resource.data.role == 'admin'
          && request.resource.data.status == 'active';

        allow create: if isAdminOrSupervisor(companyId)
          && request.resource.data.keys().hasAll(['name', 'email', 'role', 'status'])
          && request.resource.data.name is string
          && request.resource.data.email is string
          && request.resource.data.role in ['admin', 'supervisor', 'technician', 'client']
          && request.resource.data.status in ['active', 'invited'];

        allow update: if (hasActiveMembership(companyId) && request.auth.uid == memberId
            && request.resource.data.role == resource.data.role
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.status == resource.data.status
            && request.resource.data.email == resource.data.email
            && request.resource.data.name == resource.data.name)
          || (
            hasActiveMembership(companyId)
            && resource.data.uid == request.auth.uid
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status
          )
          || (isCompanyAdmin(companyId)
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status)
          || (hasActiveMembership(companyId)
            && memberRole(companyId) == 'supervisor'
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status)
          || (
            resource.data.status == 'invited'
            && request.resource.data.status == 'active'
            && request.resource.data.uid == request.auth.uid
            && request.auth.token.email != null
            && resource.data.email == request.auth.token.email
            && request.resource.data.role == resource.data.role
            && request.resource.data.name == resource.data.name
            && request.resource.data.email == resource.data.email
          );

        // Role / status changes for other members go through Cloud Functions (supervisor cannot elevate privileges client-side).
        allow delete: if isCompanyAdmin(companyId);
      }

      match /invites/{inviteId} {
        allow read, write: if false;
      }

      match /clients/{clientId} {
        allow read: if isStaff(companyId);
        allow create, update, delete: if isAdminOrSupervisor(companyId);
      }

      match /pools/{poolId} {
        allow read: if isStaff(companyId)
          || (isPortalClient(companyId) && resource.data.clientId == request.auth.uid);
        allow create: if isAdminOrSupervisor(companyId)
          && request.resource.data.keys().hasAll(['name', 'address'])
          && request.resource.data.name is string
          && request.resource.data.address is string;
        allow update: if isStaff(companyId);
        allow delete: if isAdminOrSupervisor(companyId);

        match /visits/{visitId} {
          allow read: if isStaff(companyId)
            || (isPortalClient(companyId) && poolOwnedByClient(companyId, poolId));
          allow create: if isStaff(companyId);
          allow update, delete: if isAdminOrSupervisor(companyId);
        }
      }

      match /routes/{routeId} {
        allow read: if isStaff(companyId);
        allow create: if isStaff(companyId);
        allow update: if isAdminOrSupervisor(companyId)
          || (isTechnician(companyId)
            && (resource.data.workerId == request.auth.uid
              || resource.data.workerId == ''
              || resource.data.workerId == null));
        allow delete: if isAdminOrSupervisor(companyId);
      }

      match /logs/{logId} {
        allow read: if isAdminOrSupervisor(companyId)
          || (isTechnician(companyId) && resource.data.workerId == request.auth.uid)
          || (isPortalClient(companyId)
            && poolOwnedByClient(companyId, resource.data.poolId)
            && (resource.data.status == 'ok' || resource.data.get('notifyClient', true) == true));
        allow create: if isStaff(companyId);
        allow update: if isAdminOrSupervisor(companyId);
        allow delete: if isAdminOrSupervisor(companyId);
      }
    }

    match /pools/{poolId} {
      allow read, write: if false;
      match /visits/{visitId} {
        allow read, write: if false;
      }
    }
    match /routes/{routeId} {
      allow read, write: if false;
    }
    match /logs/{logId} {
      allow read, write: if false;
    }

    match /test/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
