rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: name (string), email (string), role (string: admin|worker)
    //
    // Collection: pools
    // Fields: name (string), address (string), coordinates (map), clientId (string)
    //
    // Collection: routes
    // Fields: workerId (string), date (string), poolIds (list), status (string)
    //
    // Collection: logs
    // Fields: workerId (string), poolId (string), arrivalTime (timestamp), departureTime (timestamp), status (string), notes (string), photos (list)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "sasegura.fernandez87@gmail.com" || 
         hasRole('admin'));
    }
    
    function isWorker() {
      return hasRole('worker');
    }
    
    function isClient() {
      return hasRole('client');
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'role', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['admin', 'worker', 'client'] &&
             data.uid is string;
    }

    function isValidPool(data) {
      return data.keys().hasAll(['name', 'address']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 200;
    }

    function isValidRoute(data) {
      return data.keys().hasAll(['poolIds', 'status']) &&
             data.poolIds is list && data.poolIds.size() > 0 &&
             data.status in ['pending', 'in-progress', 'completed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow users to create their own profile, or admins to create any
      // Also allow seeding the specific demo IDs for the demo environment
      allow create: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() || 
        userId in ['demo-worker-id', 'demo-client-id']
      );
      // Allow users to update their own profile (but not their role unless they are admin)
      // For the demo, we allow self-role-update if they are owner to facilitate testing
      allow update: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow delete: if isAdmin();
    }

    // Pools collection
    match /pools/{poolId} {
      allow read: if isAuthenticated();
      // Allow admins to write, or any authenticated user to seed if the collection is empty
      // (Simplified for demo: allow any authenticated user to create pools for now)
      allow write: if isAuthenticated() && (isAdmin() || !exists(/databases/$(database)/documents/pools/seed-marker));
    }

    // Routes collection
    match /routes/{routeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || !exists(/databases/$(database)/documents/routes/seed-marker));
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isWorker() && request.resource.data.workerId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    // Logs collection
    match /logs/{logId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isWorker() || 
        (isClient() && 
         get(/databases/$(database)/documents/pools/$(resource.data.poolId)).data.clientId == request.auth.uid &&
         (resource.data.status == 'ok' || resource.data.get('notifyClient', true) == true))
      );
      allow create: if isAuthenticated() && (isAdmin() || isWorker());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
